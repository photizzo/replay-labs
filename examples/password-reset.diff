@@ -0,0 +1,23 @@
+import { describe, expect, it } from "vitest";
+import {
+  createPasswordResetToken,
+  verifyPasswordResetToken
+} from "./tokens.js";
+
+describe("password reset tokens", () => {
+  it("verifies a valid reset token", async () => {
+    const token = await createPasswordResetToken("user_123");
+
+    await expect(verifyPasswordResetToken(token)).resolves.toBe("user_123");
+  });
+
+  it("rejects an expired reset token", async () => {
+    const token = await createPasswordResetToken("user_123");
+    await expireResetToken(token);
+
+    await expect(verifyPasswordResetToken(token)).resolves.toBeNull();
+  });
+});
